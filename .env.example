# DRIFT v3 environment (all optional — the game runs fully offline in mock mode)

# Gemini (advisory narration/scene enrichment only; proxied so the key stays server-side)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Reactor (live navigable backdrop). API key stays server-side; browser gets a short-lived JWT via POST /api/reactor-token.
# Default model is lingbot (WASD-navigable). Use ?model=helios for prompt-only streaming (no flight sync).
REACTOR_API_KEY=

# Static server port
PORT=5173
